<Window x:Class="IpShow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="IpShow"
        Icon="Assets/IpShow.ico"
        Width="176"
        Height="42"
        MinWidth="176"
        MaxWidth="176"
        MinHeight="42"
        MaxHeight="42"
        SizeToContent="Manual"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#01FFFFFF"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="0"
                        GlassFrameThickness="-1"
                        ResizeBorderThickness="0"
                        CornerRadius="0"
                        UseAeroCaptionButtons="False" />
  </shell:WindowChrome.WindowChrome>
  <Window.ContextMenu>
    <ContextMenu Opened="ContextMenu_Opened">
      <MenuItem Header="DNS —" Name="DnsMenu" />
      <Separator />
      <MenuItem Header="IP 查询网站" Name="IpLookupMenu" Click="IpLookupMenu_Click" />
      <MenuItem Header="地图查询归属地" Name="MapLookupMenu" Click="MapLookupMenu_Click" />
      <Separator />
      <MenuItem Header="Google: -" Name="PingGoogleMenu" />
      <MenuItem Header="Baidu: -" Name="PingBaiduMenu" />
      <MenuItem Header="GitHub: -" Name="PingGitHubMenu" />
      <MenuItem Header="YouTube: -" Name="PingYouTubeMenu" />
      <MenuItem Header="Telegram: -" Name="PingTelegramMenu" />
      <Separator />
      <MenuItem Header="Dock Top" IsCheckable="True" Name="DockTopMenu" Click="DockTopMenu_Click" />
      <MenuItem Header="Dock Bottom" IsCheckable="True" Name="DockBottomMenu" Click="DockBottomMenu_Click" />
      <MenuItem Header="Dock Bottom (Safe)" IsCheckable="True" Name="DockBottomSafeMenu" Click="DockBottomSafeMenu_Click" />
      <MenuItem Header="Dock Top Right" IsCheckable="True" Name="DockTopRightMenu" Click="DockTopRightMenu_Click" />
      <MenuItem Header="Dock Bottom Right" IsCheckable="True" Name="DockBottomRightMenu" Click="DockBottomRightMenu_Click" />
      <Separator />
      <MenuItem Header="Free Move" IsCheckable="True" Name="DockFreeMenu" Click="DockFreeMenu_Click" />
      <MenuItem Header="Lock Current Position" IsCheckable="True" Name="DockCurrentMenu" Click="DockCurrentMenu_Click" />
      <Separator />
      <MenuItem Header="Layer">
        <MenuItem Header="Top Layer" IsCheckable="True" Name="LayerTopMenu" Click="LayerMenu_Click" />
        <MenuItem Header="Normal Layer" IsCheckable="True" Name="LayerNormalMenu" Click="LayerMenu_Click" />
        <MenuItem Header="Bottom Layer" IsCheckable="True" Name="LayerBottomMenu" Click="LayerMenu_Click" />
      </MenuItem>
      <MenuItem Header="Display">
        <MenuItem Header="Desktop Window" IsCheckable="True" Name="DisplayDesktopMenu" Click="DisplayModeMenu_Click" />
        <MenuItem Header="Tray Only" IsCheckable="True" Name="DisplayTrayOnlyMenu" Click="DisplayModeMenu_Click" />
        <Separator />
        <MenuItem Header="Show Tray Icon" IsCheckable="True" Name="ShowTrayIconMenu" Click="ShowTrayIconMenu_Click" />
      </MenuItem>
      <MenuItem Header="Balanced Text" IsCheckable="True" Name="BalancedTextMenu" Click="TextThemeMenu_Click" />
      <MenuItem Header="Light Text" IsCheckable="True" Name="LightTextMenu" Click="TextThemeMenu_Click" />
      <MenuItem Header="Dark Text" IsCheckable="True" Name="DarkTextMenu" Click="TextThemeMenu_Click" />
      <Separator />
      <MenuItem Header="Start with Windows" IsCheckable="True" Name="StartupMenu" Click="StartupMenu_Click" />
      <Separator />
      <MenuItem Header="Calendar" Name="CalendarMenu">
        <MenuItem Header="January (Jan) - 一月" Name="Month1Menu" />
        <MenuItem Header="February (Feb) - 二月" Name="Month2Menu" />
        <MenuItem Header="March (Mar) - 三月" Name="Month3Menu" />
        <MenuItem Header="April (Apr) - 四月" Name="Month4Menu" />
        <MenuItem Header="May (May) - 五月" Name="Month5Menu" />
        <MenuItem Header="June (Jun) - 六月" Name="Month6Menu" />
        <MenuItem Header="July (Jul) - 七月" Name="Month7Menu" />
        <MenuItem Header="August (Aug) - 八月" Name="Month8Menu" />
        <MenuItem Header="September (Sep) - 九月" Name="Month9Menu" />
        <MenuItem Header="October (Oct) - 十月" Name="Month10Menu" />
        <MenuItem Header="November (Nov) - 十一月" Name="Month11Menu" />
        <MenuItem Header="December (Dec) - 十二月" Name="Month12Menu" />
        <Separator />
        <MenuItem Header="Sunday (Sun) - 星期日" Name="Weekday0Menu" />
        <MenuItem Header="Monday (Mon) - 星期一" Name="Weekday1Menu" />
        <MenuItem Header="Tuesday (Tue) - 星期二" Name="Weekday2Menu" />
        <MenuItem Header="Wednesday (Wed) - 星期三" Name="Weekday3Menu" />
        <MenuItem Header="Thursday (Thu) - 星期四" Name="Weekday4Menu" />
        <MenuItem Header="Friday (Fri) - 星期五" Name="Weekday5Menu" />
        <MenuItem Header="Saturday (Sat) - 星期六" Name="Weekday6Menu" />
      </MenuItem>
      <Separator />
      <MenuItem Header="Refresh Interval">
        <MenuItem Header="5s" IsCheckable="True" Name="Refresh5Menu" Tag="5" Click="RefreshIntervalMenu_Click" />
        <MenuItem Header="10s" IsCheckable="True" Name="Refresh10Menu" Tag="10" Click="RefreshIntervalMenu_Click" />
        <MenuItem Header="30s" IsCheckable="True" Name="Refresh30Menu" Tag="30" Click="RefreshIntervalMenu_Click" />
        <MenuItem Header="60s" IsCheckable="True" Name="Refresh60Menu" Tag="60" Click="RefreshIntervalMenu_Click" />
      </MenuItem>
      <MenuItem Header="Force Refresh" Click="RefreshNowMenu_Click" />
      <MenuItem Header="Exit" Click="ExitMenu_Click" />
    </ContextMenu>
  </Window.ContextMenu>

  <Grid>
    <!-- Single glass frame over the system acrylic backdrop -->
    <Border CornerRadius="10"
            Background="#746B7078"
            BorderThickness="0"
            BorderBrush="Transparent"
            Padding="7,2">
      <Grid VerticalAlignment="Center">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center">
          <TextBlock FontFamily="Bahnschrift"
                     FontSize="14"
                     MaxWidth="92"
                     Foreground="{Binding StatusTextBrush, Mode=OneWay}"
                     Effect="{StaticResource TextGlow}"
                     TextTrimming="CharacterEllipsis"
                     Text="{Binding CurrentLocationText, Mode=OneWay}" />
          <TextBlock Foreground="{Binding StatusTextBrush, Mode=OneWay}"
                     FontFamily="Cascadia Mono, Consolas, Bahnschrift"
                     FontSize="11"
                     Margin="12,1,0,0"
                     Effect="{StaticResource TextGlow}"
                     TextTrimming="CharacterEllipsis"
                     Text="{Binding CpuUsageText, Mode=OneWay}" />
        </StackPanel>
        <Grid Grid.Row="1"
              Width="136"
              HorizontalAlignment="Center"
              Margin="0,0,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="34" />
            <ColumnDefinition Width="22" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="34" />
            <ColumnDefinition Width="22" />
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0"
                     Foreground="{Binding StatusTextBrush, Mode=OneWay}"
                     FontFamily="Cascadia Mono, Consolas, Bahnschrift"
                     FontSize="11"
                     Effect="{StaticResource TextGlow}"
                     Text="↓" />
          <TextBlock Grid.Column="1"
                     Foreground="{Binding StatusTextBrush, Mode=OneWay}"
                     FontFamily="Cascadia Mono, Consolas, Bahnschrift"
                     FontSize="11"
                     TextAlignment="Right"
                     Effect="{StaticResource TextGlow}"
                     Text="{Binding DownloadSpeedValueText, Mode=OneWay}" />
          <TextBlock Grid.Column="2"
                     Foreground="{Binding StatusTextBrush, Mode=OneWay}"
                     FontFamily="Cascadia Mono, Consolas, Bahnschrift"
                     FontSize="11"
                     Effect="{StaticResource TextGlow}"
                     Text="{Binding DownloadSpeedUnitText, Mode=OneWay}" />
          <TextBlock Grid.Column="4"
                     Foreground="{Binding StatusTextBrush, Mode=OneWay}"
                     FontFamily="Cascadia Mono, Consolas, Bahnschrift"
                     FontSize="11"
                     Effect="{StaticResource TextGlow}"
                     Text="↑" />
          <TextBlock Grid.Column="5"
                     Foreground="{Binding StatusTextBrush, Mode=OneWay}"
                     FontFamily="Cascadia Mono, Consolas, Bahnschrift"
                     FontSize="11"
                     TextAlignment="Right"
                     Effect="{StaticResource TextGlow}"
                     Text="{Binding UploadSpeedValueText, Mode=OneWay}" />
          <TextBlock Grid.Column="6"
                     Foreground="{Binding StatusTextBrush, Mode=OneWay}"
                     FontFamily="Cascadia Mono, Consolas, Bahnschrift"
                     FontSize="11"
                     Effect="{StaticResource TextGlow}"
                     Text="{Binding UploadSpeedUnitText, Mode=OneWay}" />
        </Grid>
      </Grid>
    </Border>
  </Grid>
</Window>

