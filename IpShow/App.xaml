<Application x:Class="IpShow.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
  <Application.Resources>
    <SolidColorBrush x:Key="PanelBackground" Color="#CC1D1D1D" />
    <SolidColorBrush x:Key="TextPrimary" Color="#F8F8F8" />
    <SolidColorBrush x:Key="TextSecondary" Color="#D0D0D0" />
    <SolidColorBrush x:Key="Accent" Color="#57C1FF" />
    <SolidColorBrush x:Key="PrefixConnected" Color="#58D26F" />
    <SolidColorBrush x:Key="PrefixDisconnected" Color="#9A9A9A" />
    <SolidColorBrush x:Key="LocationChina" Color="#FF5252" />
    <SolidColorBrush x:Key="LocationOther" Color="#58D26F" />
    <SolidColorBrush x:Key="LocationUnknown" Color="#9A9A9A" />
<DropShadowEffect x:Key="BannerShadow" BlurRadius="18" ShadowDepth="4" Opacity="0.35" />
    <DropShadowEffect x:Key="TextGlow" BlurRadius="1.6" ShadowDepth="0" Opacity="0.85" Color="#000000" />
  </Application.Resources>
</Application>
